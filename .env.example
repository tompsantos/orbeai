# orbeAI — variáveis de ambiente (exemplo)
# Copie para .env e ajuste. NUNCA commite o .env real.

# Identidade pública (seguro expor no client)
VITE_APP_NAME=orbeAI
VITE_APP_COMPANY=orbeOne
VITE_API_BASE_URL=
VITE_MOCK_MODE=true

# Provedores de LLM — USAR SOMENTE SERVER-SIDE.
# Nunca exponha estas chaves em builds de client em produção.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
GROQ_API_KEY=

# Banco e backend (server-side)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
