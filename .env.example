# orbeAI — variáveis de ambiente (exemplo)
# Copie para .env e ajuste. NUNCA commite o .env real.

# Identidade pública (seguro expor no client via prefixo VITE_)
VITE_APP_NAME=orbeAI
VITE_APP_COMPANY=orbeOne
VITE_API_BASE_URL=
VITE_MOCK_MODE=true

# ─── Server-side only (nunca prefixar com VITE_) ──────────────────────────────
# Provedores LLM — lidos dentro de handlers de server functions, jamais no client.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
GROQ_API_KEY=

# Banco e backend
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
