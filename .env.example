# orbeAI — variáveis de ambiente (exemplo)
# Copie para .env e ajuste. NUNCA commite o .env real.

# Identidade pública (seguro expor no client via prefixo VITE_)
VITE_APP_NAME=orbeAI
VITE_APP_COMPANY=orbeOne
VITE_API_BASE_URL=http://localhost:8000
VITE_MOCK_MODE=true
VITE_ORBEAI_DATA_MODE=mock

# ─── Server-side only (nunca prefixar com VITE_) ──────────────────────────────
# Provedores LLM — lidos dentro do backend, jamais no client.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
GROQ_API_KEY=

# Backend FastAPI
APP_ENV=local
BACKEND_CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
JWT_SECRET=dev-only-change-me

# Banco e backend
DATABASE_URL=postgresql+psycopg://orbeai:orbeai@localhost:5433/orbeai
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
